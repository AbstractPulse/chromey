{
  "manifest_version": 3,
  "name": "Chromey",
  "version": "0.2.0",
  "key": "",
  "description": "Sidepanel chat for the local Chromey server.",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "permissions": [
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "options_page": "settings.html",
  "action": {
    "default_title": "Chromey",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
